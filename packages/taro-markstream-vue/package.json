{
  "name": "taro-markstream-vue",
  "type": "module",
  "version": "1.0.1",
  "license": "MIT",
  "description": "Taro 4 streaming Markdown renderer for AI chat -- minimal Vue 3 edition",
  "keywords": [
    "taro",
    "taro4",
    "miniprogram",
    "weapp",
    "wechat",
    "vue3",
    "markdown",
    "streaming-markdown",
    "ai-chat",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lizyChy0329/taro-markstream.git"
  },
  "homepage": "https://github.com/lizyChy0329/taro-markstream#readme",
  "bugs": {
    "url": "https://github.com/lizyChy0329/taro-markstream/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/vue/index.d.mts",
      "import": "./dist/vue/index.mjs",
      "default": "./dist/vue/index.mjs"
    },
    "./index.css": {
      "import": "./dist/vue/index.css",
      "default": "./dist/vue/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "NODE_PATH=$PWD/node_modules vp pack && NODE_PATH=$PWD/node_modules vp pack --watch",
    "build": "NODE_PATH=$PWD/node_modules vp pack",
    "typecheck": "vue-tsc -b"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "markstream-core": "^1.0.3",
    "stream-markdown-parser": "^1.0.7"
  },
  "devDependencies": {
    "@tarojs/components": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tsdown/css": "^0.22.3",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "vite-plus": "^0.2.1",
    "vue": "^3.5.38",
    "vue-tsc": "^2.2.12"
  }
}