{
  "name": "taro-markstream-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "taro-markstream monorepo",
  "scripts": {
    "build": "pnpm --filter taro-markstream build",
    "dev:weapp": "pnpm --filter playground-taro dev:weapp",
    "build:weapp": "pnpm --filter playground-taro build:weapp",
    "release": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "postrelease": "git push --follow-tags origin main"
  },
  "packageManager": "pnpm@11.2.2",
  "devDependencies": {
    "standard-version": "^9.5.0"
  }
}